{
  "name": "codegraph",
  "productName": "16x CodeGraph",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Local TypeScript code-graph & targeted refactoring tool. Feed small LLMs only the code that matters.",
  "scripts": {
    "dev": "concurrently -k \"npm:dev:sidecar\" \"tauri dev\"",
    "dev:web": "concurrently -k \"npm:dev:sidecar\" \"npm:dev:vite\"",
    "dev:vite": "vite",
    "dev:sidecar": "tsx watch sidecar/src/index.ts",
    "build:web": "tsc --noEmit -p tsconfig.json && vite build",
    "build:sidecar": "esbuild sidecar/src/index.ts --bundle --platform=node --format=cjs --external:better-sqlite3 --external:ts-morph --outfile=sidecar/dist/index.cjs",
    "typecheck:sidecar": "tsc --noEmit -p sidecar/tsconfig.json",
    "build": "npm run build:web && npm run build:sidecar && tauri build",
    "tauri": "tauri"
  },
  "dependencies": {
    "@tauri-apps/api": "^2.1.1",
    "@tauri-apps/plugin-dialog": "^2.0.1",
    "better-sqlite3": "^11.5.0",
    "cors": "^2.8.5",
    "express": "^4.21.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "ts-morph": "^24.0.0"
  },
  "devDependencies": {
    "@tauri-apps/cli": "^2.1.0",
    "@types/better-sqlite3": "^7.6.11",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/node": "^20.14.0",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.1",
    "autoprefixer": "^10.4.19",
    "concurrently": "^9.0.1",
    "esbuild": "^0.24.0",
    "postcss": "^8.4.38",
    "tailwindcss": "^3.4.4",
    "tsx": "^4.19.1",
    "typescript": "^5.5.4",
    "vite": "^5.4.8"
  }
}
